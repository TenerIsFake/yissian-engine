# --- GLOBAL SERVER IP ---
SERVER_IP=your_primary_server_ip

# --- MEDIA TOKENS (injected by nginx at runtime — NOT baked into JS bundle) ---
PLEX_TOKEN=your_plex_token
TAUTULLI_API_KEY=your_tautulli_api_key

# --- SERVICE API KEYS (injected by nginx at runtime — NOT baked into JS bundle) ---
RADARR_API_KEY=your_radarr_api_key
SONARR_API_KEY=your_sonarr_api_key
LIDARR_API_KEY=your_lidarr_api_key
OVERSEERR_API_KEY=your_overseerr_api_key
PROWLARR_API_KEY=your_prowlarr_api_key

# --- DOWNLOADER CREDENTIALS (injected by nginx at runtime — NOT baked into JS bundle) ---
SABNZBD_API_KEY=your_sabnzbd_api_key
# qBittorrent uses bypass-auth-for-localhost — no credentials needed here

# --- SUBTITLE SERVICE (injected by nginx at runtime — NOT baked into JS bundle) ---
BAZARR_API_KEY=your_bazarr_api_key

# --- INTERNAL SECRET (nginx CSRF guard on qBittorrent write endpoint) ---
# Generate with: openssl rand -hex 32
# This value is checked by nginx — it never leaves the container network.
PORT_UPDATER_SECRET=your_port_updater_secret
