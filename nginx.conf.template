        allow 127.0.0.0/8;
        deny all;
        proxy_pass http://10.0.0.155:7682/api/;
        proxy_set_header Host $host;
        limit_req zone=api_general burst=30 nodelay;
    }

    # LAN-only; WebSocket upgrade required for noVNC
    location /obsidian/ {
        allow 10.0.0.0/8;
        allow 172.16.0.0/12;
        allow 192.168.0.0/16;
        allow 127.0.0.0/8;
        deny all;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 3600s;
        proxy_pass http://obsidian-remote:8080/;
        limit_req zone=api_general burst=60 nodelay;
    }

    # LAN-only
    location /abs/ {
        allow 10.0.0.0/8;
