    }

    # LAN-only
    location /kavita/ {
        allow 10.0.0.0/8;
        allow 172.16.0.0/12;
        allow 192.168.0.0/16;
        allow 127.0.0.0/8;
        deny all;
        proxy_pass http://kavita:5000/;
        proxy_set_header Host $host;
        limit_req zone=api_general burst=60 nodelay;
    }

    # P1-05: Open-Meteo — add TLS cert verification and explicit timeout
    location /api/weather/ {
        # P1-07: Added method restriction — was the only location without limit_except.
        limit_except GET HEAD { deny all; }
        proxy_pass https://api.open-meteo.com/;
        proxy_set_header Host api.open-meteo.com;
        proxy_ssl_server_name on;
        proxy_ssl_protocols TLSv1.2 TLSv1.3;
        # Verify Open-Meteo TLS certificate — CA bundle ships with nginx:1.27-alpine
        proxy_ssl_verify on;
        proxy_ssl_trusted_certificate /etc/ssl/certs/ca-certificates.crt;
        # External API may be slower than LAN services
        proxy_read_timeout 10s;
        limit_req zone=api_general burst=60 nodelay;
    }

    # P1-04: /assets/ must repeat security headers — nginx add_header does NOT inherit
    # from parent server block when a child location block defines its own add_header.
    location /assets/ {
        root /usr/share/nginx/html;
        expires 1y;
        add_header Cache-Control "public, immutable";
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-XSS-Protection "0" always;
        add_header Referrer-Policy "no-referrer" always;
        add_header Permissions-Policy "camera=(), microphone=(self), geolocation=()" always;
        add_header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data:; connect-src 'self'; font-src 'self' data:; frame-src 'self' https://open.spotify.com; frame-ancestors 'none';" always;
    }

    error_page 500 502 503 504 /50x.html;
    location = /50x.html { root /usr/share/nginx/html; }
}
